#include <stdio.h>
#include <kernel/tty.h>
#include <kernel/regs.h>
#include <kernel/io.h>

extern void gdt_install(void);
extern void idt_install(void);
extern void pic_remap(int offset1, int offset2);
extern void keyboard_install(void);
extern void timer_install(int frequency);
extern char keyboard_getchar(void);

// Цвета для вывода
#define COLOR_RED     "\033[1;31m"
#define COLOR_GREEN   "\033[1;32m"
#define COLOR_YELLOW  "\033[1;33m"
#define COLOR_BLUE    "\033[1;34m"
#define COLOR_MAGENTA "\033[1;35m"
#define COLOR_CYAN    "\033[1;36m"
#define COLOR_RESET   "\033[0m"

void kernel_main(void) {
    // Инициализация терминала
    terminal_initialize();
    
    // Цветной логотип
    printf(COLOR_CYAN);
    printf("╔════════════════════════════════╗\n");
    printf("║       NedoOS v0.1.0            ║\n");
    printf("╚════════════════════════════════╝\n");
    printf(COLOR_RESET "\n");
    
    // Инициализация системных компонентов
    printf(COLOR_YELLOW "Initializing GDT..." COLOR_RESET);
    gdt_install();
    printf(COLOR_GREEN " OK\n" COLOR_RESET);
    
    printf(COLOR_YELLOW "Remapping PIC..." COLOR_RESET);
    pic_remap(32, 40);
    printf(COLOR_GREEN " OK\n" COLOR_RESET);
    
    printf(COLOR_YELLOW "Installing IDT..." COLOR_RESET);
    idt_install();
    printf(COLOR_GREEN " OK\n" COLOR_RESET);
    
    printf(COLOR_YELLOW "Installing keyboard..." COLOR_RESET);
    keyboard_install();
    printf(COLOR_GREEN " OK\n" COLOR_RESET);
    
    printf(COLOR_YELLOW "Installing timer (100Hz)..." COLOR_RESET);
    timer_install(100);
    printf(COLOR_GREEN " OK\n" COLOR_RESET);
    
    // Включаем прерывания
    __asm__ volatile("sti");
    
    printf(COLOR_GREEN "\n✅ System ready!\n" COLOR_RESET);
    printf("Type " COLOR_YELLOW "help" COLOR_RESET " for commands\n\n");
    
    // Командная строка
    char cmd[256];
    int pos = 0;
    
    while (1) {
        printf(COLOR_CYAN "> " COLOR_RESET);
        
        pos = 0;
        while (1) {
            char c = keyboard_getchar();
            
            if (c == '\n') {
                cmd[pos] = '\0';
                printf("\n");
                break;
            } else if (c == '\b' && pos > 0) {
                pos--;
                printf("\b \b");
            } else if (c >= ' ' && c <= '~' && pos < 255) {
                cmd[pos++] = c;
                printf("%c", c);
            }
        }
        
        // Обработка команд
        if (cmd[0] == 'h' && cmd[1] == 'e' && cmd[2] == 'l' && cmd[3] == 'p') {
            printf("Commands:\n");
            printf("  " COLOR_YELLOW "help" COLOR_RESET "   - this help\n");
            printf("  " COLOR_YELLOW "clear" COLOR_RESET "  - clear screen\n");
            printf("  " COLOR_YELLOW "color" COLOR_RESET "  - show colors\n");
            printf("  " COLOR_YELLOW "info" COLOR_RESET "   - system info\n");
            printf("  " COLOR_YELLOW "time" COLOR_RESET "   - show timer ticks\n");
            printf("  " COLOR_YELLOW "echo" COLOR_RESET "   - echo command\n");
        }
        else if (cmd[0] == 'c' && cmd[1] == 'l' && cmd[2] == 'e' && cmd[3] == 'a' && cmd[4] == 'r') {
            terminal_initialize();
        }
        else if (cmd[0] == 'c' && cmd[1] == 'o' && cmd[2] == 'l' && cmd[3] == 'o' && cmd[4] == 'r') {
            printf(COLOR_RED "Red\n" COLOR_RESET);
            printf(COLOR_GREEN "Green\n" COLOR_RESET);
            printf(COLOR_YELLOW "Yellow\n" COLOR_RESET);
            printf(COLOR_BLUE "Blue\n" COLOR_RESET);
            printf(COLOR_MAGENTA "Magenta\n" COLOR_RESET);
            printf(COLOR_CYAN "Cyan\n" COLOR_RESET);
        }
        else if (cmd[0] == 'i' && cmd[1] == 'n' && cmd[2] == 'f' && cmd[3] == 'o') {
            printf("NedoOS v0.1.0 (i386)\n");
            printf("GDT, IDT, PIC: OK\n");
            printf("Keyboard: OK\n");
            printf("Timer: 100Hz\n");
        }
        else if (cmd[0] == 't' && cmd[1] == 'i' && cmd[2] == 'm' && cmd[3] == 'e') {
            extern uint32_t timer_ticks;
            printf("Timer ticks: %d\n", timer_ticks);
        }
        else if (cmd[0] == 'e' && cmd[1] == 'c' && cmd[2] == 'h' && cmd[3] == 'o') {
            if (cmd[5] != '\0') {
                printf("%s\n", cmd + 5);
            }
        }
        else if (cmd[0] != '\0') {
            printf("Unknown command: " COLOR_RED "%s\n" COLOR_RESET, cmd);
        }
    }
}
